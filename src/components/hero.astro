---
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon";

export interface Props {
  variant?: "install" | "conversion";
}

const { variant = "install" } = Astro.props;
const isConversion = variant === "conversion";
const heroTitle = isConversion
  ? "Turn WhatsApp Conversations Into Qualified Revenue"
  : "Automate WhatsApp Follow-Ups and Close More Deals";
const heroDesc = isConversion
  ? "Capture leads, automate follow-ups, and keep every reply on brand from one extension."
  : "AI replies, lead follow-ups, and team-safe automation in one Chrome extension.";
const secondaryHref = "/pricing";
const secondaryLabel = "Compare Plans";
const secondaryCta = "hero_compare_plans";
---

<section class="pt-10 pb-6 md:pt-14 md:pb-10">
  <div class="max-w-4xl mx-auto text-center">
    <p class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-pink-600 bg-[var(--brand-50)] border border-[var(--line-soft)] rounded-full px-3 py-1">
      <span class="w-2 h-2 rounded-full bg-pink-500"></span>
      WhatsApp Growth Assistant for Teams
    </p>

    <h1 class="mt-5 text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight tracking-tight text-gray-900">
      {heroTitle}
    </h1>

    <p class="mx-auto mt-6 max-w-2xl text-center text-lg leading-relaxed text-gray-700">
      {heroDesc}
    </p>

    <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-amber-200 bg-amber-50 px-4 py-2 text-sm font-semibold text-amber-800">
      <span class="inline-block h-2 w-2 rounded-full bg-amber-500"></span>
      Limited-time offer: Pro $9.9/mo, Max $19.9/mo
    </div>

    <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
      <Link
        href="https://chromewebstore.google.com/detail/agent-for-whatsapp/kjeodciaphncjcogidpafdeeckmpdcpn"
        data-cta="hero_install_free"
        data-location="hero"
        target="_blank"
        class="flex gap-2 items-center justify-center bg-pink-600 hover:bg-pink-700 rounded-xl text-white font-semibold"
        rel="noopener">
        <Icon class="text-white w-5 h-5" name="bx:bxl-chrome" />
        Install Free on Chrome
      </Link>

      <Link
        size="lg"
        rel="noopener"
        href={secondaryHref}
        data-cta={secondaryCta}
        data-location="hero"
        class="flex gap-2 items-center justify-center bg-white border border-[var(--line-soft)] text-gray-900 rounded-xl hover:bg-[var(--brand-50)] font-semibold"
      >
        <Icon class="text-pink-600 w-5 h-5" name="mdi:scale-balance" />
        {secondaryLabel}
      </Link>
    </div>

    <div class="mt-6 grid grid-cols-2 sm:grid-cols-4 gap-2 text-sm text-gray-700">
      <span class="px-3 py-1 rounded-full border border-[var(--line-soft)] bg-white text-center">5 min setup</span>
      <span class="px-3 py-1 rounded-full border border-[var(--line-soft)] bg-white text-center">4+ AI connectors</span>
      <span class="px-3 py-1 rounded-full border border-[var(--line-soft)] bg-white text-center">Toolbox workflow</span>
      <span class="px-3 py-1 rounded-full border border-[var(--line-soft)] bg-white text-center">12 languages</span>
    </div>
  </div>
</section>
