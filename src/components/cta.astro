---
import Link from "./ui/link.astro";
import type { Locale } from "@lib/i18n";
import { getSiteCopy } from "@lib/site-copy";
import { localizePath } from "@lib/i18n";

export interface Props {
  variant?: "install" | "conversion";
  locale?: Locale;
}

const { variant = "install", locale = "en" } = Astro.props;
const isConversion = variant === "conversion";
const copy = getSiteCopy(locale);
---

<section class="rounded-3xl bg-[var(--ink-900)] px-6 py-14 sm:px-10 sm:py-16 text-center">
  <p class="text-xs font-semibold uppercase tracking-widest text-[var(--brand-500)]">{copy.cta.eyebrow}</p>
  <h2 class="mx-auto mt-4 max-w-2xl text-3xl font-bold tracking-tight text-white lg:text-4xl">
    {isConversion
      ? copy.cta.conversionTitle
      : copy.cta.installTitle}
  </h2>
  <p class="mx-auto mt-4 max-w-xl text-base leading-7 text-slate-300">
    {isConversion
      ? copy.cta.conversionDesc
      : copy.cta.installDesc}
  </p>

  <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
    <Link
      href={isConversion ? localizePath("/pricing", locale) : "https://chromewebstore.google.com/detail/agent-for-whatsapp/kjeodciaphncjcogidpafdeeckmpdcpn"}
      data-cta={isConversion ? "final_open_pricing" : "final_install"}
      data-location="final_cta"
      class="btn-primary rounded-xl px-7 py-3.5 font-semibold shadow-lg shadow-green-500/30"
      target={isConversion ? undefined : "_blank"}
      rel={isConversion ? undefined : "noopener"}
    >
      {isConversion ? copy.cta.conversionPrimary : copy.cta.installPrimary}
    </Link>
    <Link
      href={localizePath("/docs", locale)}
      data-cta="final_read_docs"
      data-location="final_cta"
      class="rounded-xl border border-slate-600 px-7 py-3.5 font-semibold text-white transition hover:bg-slate-800"
    >
      {copy.cta.secondary}
    </Link>
  </div>
</section>
