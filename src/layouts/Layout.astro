---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import "@fontsource/inter/variable.css";
import type { Locale } from "@lib/i18n";

export interface Props {
  title: string;
  description?: string;
  expId?: string;
  expVariant?: string;
  locale?: Locale;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const { title, description, expId = "", expVariant = "", locale = "en" } = Astro.props;

const makeTitle = title
  ? `${title} | Agent for WhatsApp`
  : "Agent for WhatsApp - Automate Replies & Manage Conversations";
const ogTitle = title
  ? `${title} - Agent for WhatsApp`
  : "Agent for WhatsApp";
const makeDescription =
  description ??
  "Automate replies, manage conversations, and stay productive on WhatsApp Web. Connect OpenAI, OpenRouter, Groq, or local models. Includes lead management, persona settings, and automation workflows.";
const keywords = [
  "agent for whatsapp",
  "whatsapp automation",
  "whatsapp ai assistant",
  "whatsapp auto reply",
  "whatsapp bot chrome extension",
  "whatsapp lead management",
  "ai connector openai openrouter groq",
  "whatsapp persona settings",
  "whatsapp message workflow",
  "whatsapp chrome extension",
].join(", ");
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="keywords" content={keywords} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- <link rel="preload" as="image" href={src} alt="Hero" /> -->
    <SEO
      title={makeTitle}
      description={makeDescription}
      canonical={canonicalURL}
      twitter={{
        creator: "@AIFunFace",
        site: "https://aoq.me",
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: "website",
          title: ogTitle,
          image: resolvedImageWithDomain,
        },
        image: {
          alt: "Agent for WhatsApp - Homepage Screenshot",
        },
      }}
    />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-TZ84NX7M1H"
    ></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-TZ84NX7M1H");
    </script>
  </head>
  <body data-exp-id={expId} data-exp-variant={expVariant}>
    <div class="site-bg"></div>
    <Navbar locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
    <script is:inline>
      const body = document.body;
      const pageExpId = body?.dataset?.expId || "";
      const pageExpVariant = body?.dataset?.expVariant || "";

      if (typeof window.gtag === "function" && pageExpId && pageExpVariant) {
        window.gtag("event", "lp_view", {
          exp_id: pageExpId,
          exp_variant: pageExpVariant,
          page_path: window.location.pathname,
        });
      }

      document.addEventListener("click", (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const ctaEl = target.closest("a[data-cta],button[data-cta]");
        if (!ctaEl) return;

        const ctaName = ctaEl.getAttribute("data-cta") || "unknown_cta";
        const ctaLocation = ctaEl.getAttribute("data-location") || "unknown";
        const href = ctaEl.getAttribute("href") || "";
        const ctaExpId = ctaEl.getAttribute("data-exp-id") || pageExpId;
        const ctaExpVariant =
          ctaEl.getAttribute("data-exp-variant") || pageExpVariant;

        if (typeof window.gtag === "function") {
          window.gtag("event", "cta_click", {
            cta_name: ctaName,
            cta_location: ctaLocation,
            cta_href: href,
            exp_id: ctaExpId,
            exp_variant: ctaExpVariant,
          });
        }
      });
    </script>
    <style is:global>
      :root {
        --brand-50: #e8f5e9;
        --brand-100: #c8e6c9;
        --brand-500: #22c55e;
        --brand-600: #16a34a;
        --cta-500: #22c55e;
        --cta-600: #16a34a;
        --ink-900: #0f172a;
        --ink-700: #475569;
        --line-soft: #e2e8f0;
        --card-bg: #ffffff;
        --surface: #fafbfc;
      }

      html,
      body {
        background: var(--surface);
        color: var(--ink-900);
        font-family: "InterVariable", Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }

      html[lang="zh"] body {
        font-family: "PingFang SC", "SF Pro SC", "Hiragino Sans GB", "Noto Sans CJK SC", "Source Han Sans SC", "Microsoft YaHei", sans-serif;
      }

      html[lang="zh"] h1,
      html[lang="zh"] h2,
      html[lang="zh"] h3,
      html[lang="zh"] .section-title {
        font-family: "PingFang SC", "SF Pro SC", "Hiragino Sans GB", "Noto Sans CJK SC", "Source Han Sans SC", "Microsoft YaHei", sans-serif;
        font-weight: 800;
        letter-spacing: -0.045em;
      }

      main {
        position: relative;
        z-index: 1;
      }

      .site-bg {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: 0;
        background-image:
          radial-gradient(circle at 50% -8%, rgba(34, 197, 94, 0.08), transparent 36%),
          radial-gradient(circle at 80% 60%, rgba(34, 197, 94, 0.04), transparent 30%),
          linear-gradient(180deg, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0));
      }

      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }

      .eyebrow {
        font-size: 0.74rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--brand-600);
        font-weight: 600;
      }

      html[lang="zh"] .eyebrow {
        letter-spacing: 0.08em;
      }

      .section-title {
        color: var(--ink-900);
        font-weight: 700;
        letter-spacing: -0.03em;
      }

      .surface-card {
        background: #ffffff;
        border: 1px solid var(--line-soft);
        border-radius: 1.25rem;
        transition: box-shadow 0.2s ease, transform 0.2s ease;
      }

      .surface-card:hover {
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
      }

      .btn-primary {
        background: var(--cta-600);
        color: white;
        transition: background 0.2s ease, transform 0.15s ease;
      }

      .btn-primary:hover {
        background: var(--cta-500);
        transform: translateY(-1px);
      }

      .btn-secondary {
        background: #ffffff;
        color: var(--ink-900);
        border: 1px solid var(--line-soft);
        transition: background 0.2s ease, border-color 0.2s ease;
      }

      .btn-secondary:hover {
        background: var(--brand-50);
        border-color: var(--brand-500);
      }

      .btn-dark {
        background: var(--ink-900);
        color: white;
        transition: background 0.2s ease, transform 0.15s ease;
      }

      .btn-dark:hover {
        background: #1e293b;
        transform: translateY(-1px);
      }
    </style>
  </body>
</html>
