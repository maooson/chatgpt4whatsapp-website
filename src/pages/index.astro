---
import Container from "@components/container.astro";
import Cta from "@components/cta.astro";
import Features from "@components/features.astro";
import Footer from "@components/footer.astro";
import Hero from "@components/hero.astro";
import Logos from "@components/logos.astro";
import Proof from "@components/proof.astro";
import Layout from "@layouts/Layout.astro";
import Howtouse from "@components/howtouse.astro";
import Faq from "@components/faq.astro";
---

<Layout
  title="Agent for WhatsApp"
  description="Automate WhatsApp replies, run lead follow-up workflows, and keep team conversations on-brand. Connect OpenAI/OpenRouter/Groq/Gemini/Local models and launch in minutes."
  expId="lp_home"
  expVariant="install_v1"
>
  <Container>
    <Hero variant="install" />

    <section class="mt-14">
      <Proof />
    </section>

    <section class="mt-14">
      <Features />
    </section>

    <section class="mt-14">
      <Howtouse />
    </section>

    <section class="mt-14">
      <Cta variant="install" />
    </section>

    <section class="mt-14">
      <Faq />
    </section>

    <section class="mt-14">
      <Logos />
    </section>
  </Container>
</Layout>
