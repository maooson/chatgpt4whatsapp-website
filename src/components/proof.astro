---
import { Icon } from "astro-icon/components";
import type { Locale } from "@lib/i18n";
import { getSiteCopy } from "@lib/site-copy";

const { locale = "en" } = Astro.props as { locale?: Locale };
const copy = getSiteCopy(locale);
const stats = copy.proof.stats;

const providers = [
  { name: "OpenAI", icon: "simple-icons:openai" },
  { name: "Google", icon: "simple-icons:google" },
  { name: "Meta", icon: "simple-icons:meta" },
  { name: "Ollama", icon: "simple-icons:ollama" },
  { name: "OpenRouter", icon: "simple-icons:openrouter" },
];
---

<section>
  <!-- Provider logos -->
  <div class="flex flex-wrap items-center justify-center gap-8 opacity-60">
    {providers.map((p) => (
      <div class="flex items-center gap-2 text-[var(--ink-700)]">
        <Icon name={p.icon} class="w-5 h-5" />
        <span class="text-sm font-medium">{p.name}</span>
      </div>
    ))}
  </div>

  <!-- Stats bar -->
  <div class="mt-10 rounded-2xl border border-[var(--line-soft)] bg-white p-6 sm:p-8">
    <p class="mb-6 text-center text-sm font-semibold uppercase tracking-widest text-[var(--brand-600)]">{copy.proof.statsTitle}</p>
    <div class="grid grid-cols-2 gap-6 sm:grid-cols-4">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-3xl font-extrabold tracking-tight text-[var(--ink-900)] lg:text-4xl">{stat.value}</div>
          <p class="mt-1 text-sm text-[var(--ink-700)]">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
