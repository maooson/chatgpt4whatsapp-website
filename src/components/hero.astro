---
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
import Container from "@components/container.astro";
import type { Locale } from "@lib/i18n";
import { getSiteCopy } from "@lib/site-copy";
import { localizePath } from "@lib/i18n";

export interface Props {
  variant?: "install" | "conversion";
  locale?: Locale;
}

const { variant = "install", locale = "en" } = Astro.props;
const isConversion = variant === "conversion";
const copy = getSiteCopy(locale);
const isZh = locale === "zh";
---

<section class="relative overflow-hidden pb-16 pt-12 md:pb-24 md:pt-20">
  <!-- Green decorative background -->
  <div class="absolute inset-x-0 top-0 -z-10 h-[520px] rounded-b-[3rem] bg-gradient-to-b from-[#d4f5e0] via-[#e8f9ef] to-transparent"></div>

  <Container>
    <div class="mx-auto max-w-4xl text-center">
      <p class="eyebrow">{copy.hero.eyebrow}</p>

      <h1
        class:list={[
          "mt-5 font-bold text-[var(--ink-900)] [text-wrap:balance]",
          isZh
            ? "mx-auto max-w-5xl text-[2.75rem] leading-[1.18] tracking-[-0.04em] sm:text-[3.45rem] lg:text-[4.25rem]"
            : "text-4xl leading-[1.08] tracking-tight sm:text-5xl lg:text-6xl",
        ]}>
        {isConversion
          ? copy.hero.conversionTitle
          : copy.hero.installTitle}
      </h1>

      <p
        class:list={[
          "mx-auto mt-6 text-[var(--ink-700)] [text-wrap:balance]",
          isZh
            ? "max-w-3xl text-[1.05rem] leading-8 sm:text-lg"
            : "max-w-2xl text-lg leading-8",
        ]}>
        {isConversion
          ? copy.hero.conversionDesc
          : copy.hero.installDesc}
      </p>

      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <Link
          href="https://chromewebstore.google.com/detail/agent-for-whatsapp/kjeodciaphncjcogidpafdeeckmpdcpn"
          data-cta="hero_install_free"
          data-location="hero"
          target="_blank"
          rel="noopener"
          class="btn-primary flex items-center justify-center gap-2 rounded-xl px-7 py-3.5 text-base font-semibold shadow-lg shadow-green-500/20"
        >
          <Icon class="h-5 w-5 text-white" name="bx:bxl-chrome" />
          {copy.hero.primaryCta}
        </Link>

        <Link
          href={localizePath("/pricing", locale)}
          data-cta="hero_compare_plans"
          data-location="hero"
          class="btn-secondary flex items-center justify-center gap-2 rounded-xl px-7 py-3.5 text-base font-semibold"
        >
          {copy.hero.secondaryCta}
        </Link>
      </div>

      <p class="mt-5 text-sm text-[var(--ink-700)]">
        {copy.hero.footnote}
      </p>
    </div>
  </Container>
</section>
