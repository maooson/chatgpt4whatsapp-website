---
import Container from "@components/container.astro";
import Cta from "@components/cta.astro";
import Features from "@components/features.astro";
import Hero from "@components/hero.astro";
import Logos from "@components/logos.astro";
import Proof from "@components/proof.astro";
import Layout from "@layouts/Layout.astro";
import Howtouse from "@components/howtouse.astro";
import Faq from "@components/faq.astro";
---

<Layout
  title="Agent for WhatsApp - Install"
  description="Install Agent for WhatsApp and launch AI-powered reply, lead, and follow-up workflows in minutes."
  expId="lp_ab"
  expVariant="install_v1"
>
  <Container>
    <Hero variant="install" />
    <Proof />
    <Features />
    <Howtouse />
    <Cta variant="install" />
    <Faq />
    <Logos />
  </Container>
</Layout>
