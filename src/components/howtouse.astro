---
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon";
---

<section class="rounded-3xl border border-[var(--line-soft)] bg-white p-6 sm:p-8 lg:p-10 shadow-sm">
  <div class="space-y-8">
    <div>
      <p class="text-xs uppercase tracking-[0.18em] text-pink-600 font-semibold">How It Works</p>
      <h2 class="mt-3 text-3xl lg:text-4xl font-bold tracking-tight text-gray-900">Go Live in Minutes</h2>
      <p class="mt-4 text-gray-600">The extension includes onboarding, setup checks, and quick links to connectors, toolbox, and settings.</p>

      <div class="mt-8 grid md:grid-cols-3 gap-4">
        <div class="rounded-2xl border border-[var(--line-soft)] p-5 bg-[var(--brand-50)] h-full">
          <p class="text-sm font-semibold text-pink-700">Step 1</p>
          <h3 class="font-semibold text-gray-900 mt-1">Install + open WhatsApp Web</h3>
          <p class="text-gray-600 mt-1">Add extension from Chrome Web Store, keep WhatsApp Web logged in, and pin the extension for fast access.</p>
        </div>

        <div class="rounded-2xl border border-[var(--line-soft)] p-5 bg-white h-full">
          <p class="text-sm font-semibold text-pink-700">Step 2</p>
          <h3 class="font-semibold text-gray-900 mt-1">Choose AI connector and test</h3>
          <p class="text-gray-600 mt-1">Connect OpenAI/OpenRouter/Groq/Gemini/Local, run test connection, then save your active model.</p>
        </div>

        <div class="rounded-2xl border border-[var(--line-soft)] p-5 bg-white h-full">
          <p class="text-sm font-semibold text-pink-700">Step 3</p>
          <h3 class="font-semibold text-gray-900 mt-1">Turn on workflows</h3>
          <p class="text-gray-600 mt-1">Enable trigger mode, configure persona, and use toolbox modules for lead, batch, and scheduled follow-up.</p>
        </div>
      </div>
    </div>

    <div class="rounded-2xl border border-[var(--line-soft)] bg-[var(--brand-50)] p-6">
      <p class="text-sm uppercase tracking-[0.12em] text-pink-700 font-semibold">Quick Start Checklist</p>
      <ul class="mt-4 space-y-3 text-sm text-gray-700">
        <li class="flex items-start gap-2">
          <Icon name="mdi:check-circle" class="w-5 h-5 text-pink-500 mt-0.5" />
          <span>WhatsApp connection status is <strong>Connected</strong></span>
        </li>
        <li class="flex items-start gap-2">
          <Icon name="mdi:check-circle" class="w-5 h-5 text-pink-500 mt-0.5" />
          <span>Connector test passed and model source is selected</span>
        </li>
        <li class="flex items-start gap-2">
          <Icon name="mdi:check-circle" class="w-5 h-5 text-pink-500 mt-0.5" />
          <span>Bot behavior, limits, and persona are configured</span>
        </li>
        <li class="flex items-start gap-2">
          <Icon name="mdi:check-circle" class="w-5 h-5 text-pink-500 mt-0.5" />
          <span>Lead/Batch/Scheduled tools are ready for campaigns</span>
        </li>
      </ul>

      <div class="mt-6 flex flex-col sm:flex-row gap-3">
        <Link
          href="https://chromewebstore.google.com/detail/agent-for-whatsapp/kjeodciaphncjcogidpafdeeckmpdcpn"
          data-cta="howto_install"
          data-location="howto"
          target="_blank"
          rel="noopener"
          class="bg-pink-600 hover:bg-pink-700 text-white rounded-xl font-semibold text-center"
        >
          Install Free
        </Link>
        <Link
          href="/pricing"
          data-cta="howto_view_pricing"
          data-location="howto"
          class="bg-white border border-[var(--line-soft)] rounded-xl font-semibold text-gray-900 hover:bg-[var(--brand-50)] text-center"
        >
          Compare Plans
        </Link>
      </div>
    </div>
  </div>
</section>
