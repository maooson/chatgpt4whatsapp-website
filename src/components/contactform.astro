---
import type { Locale } from "@lib/i18n";
import { getSiteCopy } from "@lib/site-copy";

const { locale = "en" } = Astro.props as { locale?: Locale };
const copy = getSiteCopy(locale);
---

<!-- To make this contact form work, create your free access key from https://web3forms.com/
     Then you will get all form submissions in your email inbox. -->
<form
  action="https://api.web3forms.com/submit"
  method="POST"
  id="form"
  class="needs-validation"
  data-sending={copy.contactForm.sending}
  data-fallback-error={copy.contactForm.fallbackError}
  novalidate>
  <input type="hidden" name="access_key" value="3e09e703-a081-4fa1-8a09-2fc522ec7f3d" />
  <!-- Create your free access key from https://web3forms.com/ -->
  <input type="checkbox" class="hidden" style="display:none" name="botcheck" />
  <div class="mb-5">
    <input
      type="text"
      placeholder={copy.contactForm.name}
      required
      class="w-full px-4 py-3 border border-[var(--line-soft)] placeholder:text-slate-400 text-[var(--ink-900)] bg-[var(--surface)] rounded-xl outline-none focus:ring-4 focus:ring-[var(--brand-500)]/20 focus:border-[var(--brand-500)] transition shadow-sm"
      name="name"
    />
    <div class="empty-feedback invalid-feedback text-red-400 text-sm mt-1">
      {copy.contactForm.nameError}
    </div>
  </div>
  <div class="mb-5">
    <label for="email_address" class="sr-only">{copy.contactForm.email}</label><input
      id="email_address"
      type="email"
      placeholder={copy.contactForm.email}
      name="email"
      required
      class="w-full px-4 py-3 border border-[var(--line-soft)] placeholder:text-slate-400 text-[var(--ink-900)] bg-[var(--surface)] rounded-xl outline-none focus:ring-4 focus:ring-[var(--brand-500)]/20 focus:border-[var(--brand-500)] transition shadow-sm"
    />
    <div class="empty-feedback text-red-400 text-sm mt-1">
      {copy.contactForm.emailError}
    </div>
    <div class="invalid-feedback text-red-400 text-sm mt-1">
      {copy.contactForm.emailInvalid}
    </div>
  </div>
  <div class="mb-3">
    <textarea
      name="message"
      required
      placeholder={copy.contactForm.message}
      class="w-full px-4 py-3 border border-[var(--line-soft)] placeholder:text-slate-400 text-[var(--ink-900)] bg-[var(--surface)] rounded-xl outline-none h-36 focus:ring-4 focus:ring-[var(--brand-500)]/20 focus:border-[var(--brand-500)] transition shadow-sm"
    ></textarea>
    <div class="empty-feedback invalid-feedback text-red-400 text-sm mt-1">
      {copy.contactForm.messageError}
    </div>
  </div>
  <button type="submit" class="btn-primary mt-2 flex w-full justify-center rounded-xl px-7 py-3.5 text-base font-semibold shadow-lg shadow-green-500/20 transition hover:scale-[1.02]">
    {copy.contactForm.submit}
  </button>
  <div id="result" class="mt-3 text-center"></div>
</form>

<style>
  .invalid-feedback,
  .empty-feedback {
    display: none;
  }

  .was-validated :placeholder-shown:invalid ~ .empty-feedback {
    display: block;
  }

  .was-validated :not(:placeholder-shown):invalid ~ .invalid-feedback {
    display: block;
  }

  .is-invalid,
  .was-validated :invalid {
    border-color: #dc3545;
  }
</style>

<script is:inline>
  const form = document.getElementById("form");
  const result = document.getElementById("result");

  form.addEventListener("submit", function (e) {
    e.preventDefault();
    form.classList.add("was-validated");
    if (!form.checkValidity()) {
      form.querySelectorAll(":invalid")[0].focus();
      return;
    }
    const formData = new FormData(form);
    const object = Object.fromEntries(formData);
    const json = JSON.stringify(object);

    result.innerHTML = form.dataset.sending || "";

    fetch("https://api.web3forms.com/submit", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Accept: "application/json",
      },
      body: json,
    })
      .then(async (response) => {
        let json = await response.json();
        if (response.status == 200) {
          result.classList.add("text-pink-500");
          result.innerHTML = json.message;
        } else {
          console.log(response);
          result.classList.add("text-red-500");
          result.innerHTML = json.message;
        }
      })
      .catch((error) => {
        console.log(error);
        result.innerHTML = form.dataset.fallbackError || "";
      })
      .then(function () {
        form.reset();
        form.classList.remove("was-validated");
        setTimeout(() => {
          result.style.display = "none";
        }, 5000);
      });
  });
</script>
