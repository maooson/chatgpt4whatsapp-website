---
import type { Locale } from "@lib/i18n";
import { getSiteCopy } from "@lib/site-copy";
import { localizePath } from "@lib/i18n";

const { locale = "en" } = Astro.props as { locale?: Locale };
const copy = getSiteCopy(locale);
const faqItems = copy.faq.items.map((item) => ({ ...item, link: localizePath(item.link, locale) }));
---

<section>
  <div class="mx-auto max-w-3xl text-center">
    <p class="eyebrow">{copy.faq.eyebrow}</p>
    <h2 class="section-title mt-3 text-3xl lg:text-4xl">{copy.faq.title}</h2>
  </div>

  <div class="mx-auto mt-10 max-w-3xl divide-y divide-[var(--line-soft)]">
    {
      faqItems.map((item) => (
        <details class="group py-5">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-4 font-semibold text-[var(--ink-900)]">
            <span>{item.question}</span>
            <span class="shrink-0 text-[var(--brand-600)] transition group-open:rotate-45">+</span>
          </summary>
          <p class="mt-3 leading-relaxed text-[var(--ink-700)]">{item.answer}</p>
          <a href={item.link} class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-[var(--brand-600)] hover:text-[var(--brand-500)] transition">
            {copy.faq.learnMore}
          </a>
        </details>
      ))
    }
  </div>
</section>
