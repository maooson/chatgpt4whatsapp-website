---
import { Icon } from "astro-icon/components";
import type { Locale } from "@lib/i18n";
import { getSiteCopy } from "@lib/site-copy";

const { locale = "en" } = Astro.props as { locale?: Locale };
const copy = getSiteCopy(locale);
const steps = copy.how.steps.map((step, index) => ({
  ...step,
  icon: ["mdi:download-circle", "mdi:link-variant", "mdi:rocket-launch"][index],
}));
---

<section>
  <div class="mx-auto max-w-3xl text-center">
    <p class="eyebrow">{copy.how.eyebrow}</p>
    <h2 class="section-title mt-3 text-3xl lg:text-5xl">{copy.how.title}</h2>
    <p class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-[var(--ink-700)]">
      {copy.how.desc}
    </p>
  </div>

  <div class="mx-auto mt-12 max-w-3xl space-y-6">
    {steps.map((step) => (
      <div class="surface-card flex items-center gap-5 p-6">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-[var(--brand-50)]">
          <Icon name={step.icon} class="h-6 w-6 text-[var(--brand-600)]" />
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[var(--brand-600)]">{copy.how.stepLabel} {step.num}</p>
          <h3 class="mt-1 text-lg font-bold text-[var(--ink-900)]">{step.title}</h3>
          <p class="mt-2 text-sm leading-6 text-[var(--ink-700)]">{step.text}</p>
        </div>
      </div>
    ))}
  </div>

</section>
