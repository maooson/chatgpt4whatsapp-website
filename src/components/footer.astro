---
import type { Locale } from "@lib/i18n";
import { getSiteCopy } from "@lib/site-copy";
import { localizePath } from "@lib/i18n";

const { locale = "en" } = Astro.props as { locale?: Locale };
const copy = getSiteCopy(locale);
const footerLinks = copy.footer.groups.map((group) => ({
  ...group,
  links: group.links.map((link) => ({
    ...link,
    href: localizePath(link.href, locale),
  })),
}));
---

<footer class="mt-20 pb-8">
  <div class="mx-auto max-w-7xl px-5 sm:px-6 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4 border-t border-[var(--line-soft)] pt-12">
      {footerLinks.map((group) => (
        <div>
          <h4 class="text-sm font-bold uppercase tracking-wider text-[var(--ink-900)]">{group.title}</h4>
          <ul class="mt-4 space-y-2.5">
            {group.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-[var(--ink-700)] transition hover:text-[var(--brand-600)]"
                  target={link.href.startsWith("http") ? "_blank" : undefined}
                  rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col items-center justify-between gap-3 border-t border-[var(--line-soft)] pt-6 sm:flex-row">
      <p class="text-sm text-[var(--ink-700)]">
        © {new Date().getFullYear()} Agent for WhatsApp. {copy.footer.copyright}
      </p>
      <p class="text-xs text-slate-400">
        {copy.footer.madeBy} <a href="https://aoq.me" target="_blank" rel="noopener" class="hover:underline">AOQ.ME</a>
      </p>
    </div>
  </div>
</footer>
