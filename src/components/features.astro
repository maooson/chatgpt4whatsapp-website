---
import { Icon } from "astro-icon/components";
import type { Locale } from "@lib/i18n";
import { getSiteCopy } from "@lib/site-copy";

const { locale = "en" } = Astro.props as { locale?: Locale };
const copy = getSiteCopy(locale);
const features = copy.features.cards.map((card, index) => ({
  // Use a single professional icon set to keep visual language consistent.
  icon: ["mdi:message-text-outline", "mdi:account-multiple-outline", "mdi:workflow"][index],
  ...card,
}));
---

<section>
  <div class="mx-auto max-w-3xl text-center">
    <p class="eyebrow">{copy.features.eyebrow}</p>
    <h2 class="section-title mt-3 text-3xl lg:text-5xl">{copy.features.title}</h2>
    <p class="mx-auto mt-4 max-w-2xl text-lg leading-8 text-[var(--ink-700)]">
      {copy.features.desc}
    </p>
  </div>

  <div class="mt-12 grid gap-6 lg:grid-cols-3">
    {features.map((f) => (
      <div class="surface-card p-7">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-[var(--brand-50)]">
          <Icon name={f.icon} class="h-6 w-6 text-[var(--brand-600)]" />
        </div>
        <h3 class="mt-5 text-lg font-bold text-[var(--ink-900)]">{f.title}</h3>
        <p class="mt-2 text-sm leading-6 text-[var(--ink-700)]">{f.desc}</p>
        <ul class="mt-4 space-y-2">
          {f.items.map((item) => (
            <li class="flex items-center gap-2 text-sm text-[var(--ink-700)]">
              <Icon name="mdi:check-circle" class="h-4 w-4 shrink-0 text-[var(--brand-600)]" />
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
