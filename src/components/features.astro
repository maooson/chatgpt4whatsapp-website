---
import { Icon } from "astro-icon";

const useCases = [
  {
    title: "Customer Support",
    outcome: "Reply faster with consistent tone",
    points: [
      "Auto-draft answers in private chats",
      "Use persona boundaries to avoid off-brand replies",
      "Pause automation with quiet hours when needed",
    ],
    icon: "mdi:headset",
  },
  {
    title: "Sales Follow-up",
    outcome: "Move more leads to next step",
    points: [
      "Capture and tag leads from WhatsApp chats",
      "Schedule follow-up sequences from batch sender",
      "Track progress by status: New to Won",
    ],
    icon: "mdi:chart-line",
  },
  {
    title: "Team Operations",
    outcome: "Keep workflows predictable",
    points: [
      "Switch model providers by cost and speed",
      "Control trigger mode, limits, and reply channels",
      "Review usage trend and automation status in dashboard",
    ],
    icon: "mdi:account-group",
  },
];
---

<section>
  <div class="text-center max-w-3xl mx-auto">
    <p class="text-xs uppercase tracking-[0.18em] text-pink-600 font-semibold">Use Cases</p>
    <h2 class="mt-3 text-3xl lg:text-4xl font-bold tracking-tight text-gray-900">Designed for Revenue-Critical Conversations</h2>
    <p class="mt-4 text-gray-600">From inbound support to outbound follow-up, Agent for WhatsApp turns scattered chats into repeatable workflows.</p>
  </div>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 mt-10 gap-4">
    {
      useCases.map((item) => (
        <article class="rounded-2xl border border-[var(--line-soft)] bg-white p-6 shadow-sm">
          <div class="w-11 h-11 rounded-xl bg-[var(--brand-50)] border border-[var(--line-soft)] flex items-center justify-center">
            <Icon class="text-pink-600 w-6 h-6" name={item.icon} />
          </div>
          <h3 class="font-semibold text-lg text-gray-900 mt-4">{item.title}</h3>
          <p class="mt-1 text-sm text-pink-700 font-medium">{item.outcome}</p>
          <ul class="mt-3 space-y-2 text-sm text-gray-600">
            {item.points.map((point) => <li>• {point}</li>)}
          </ul>
        </article>
      ))
    }
  </div>
</section>
