---
import Link from "./ui/link.astro";
import { Icon } from "astro-icon";

export interface Props {
  variant?: "install" | "conversion";
}

const { variant = "install" } = Astro.props;
const isConversion = variant === "conversion";
---

<section class="rounded-3xl border border-[var(--line-soft)] bg-white shadow-sm">
  <div class="p-6 sm:p-8 lg:p-10">
      <p class="text-xs uppercase tracking-[0.18em] text-pink-600 font-semibold">Ready to Scale</p>
      <h2 class="mt-3 text-3xl lg:text-4xl font-bold tracking-tight text-gray-900">
        {isConversion ? "Choose the Right Plan for Your Campaign Volume" : "Scale from First Install to Daily Throughput"}
      </h2>
      <p class="mt-4 text-gray-600">
        {isConversion
          ? "Start with Free, then move to Pro or Max when outbound volume and queue demand grow."
          : "Start free, validate workflow fit, then upgrade only when you need more queue capacity and controls."}
      </p>

      <div class="mt-6 grid sm:grid-cols-3 gap-3">
        <div class="rounded-xl border border-[var(--line-soft)] bg-[var(--brand-50)] p-4">
          <p class="text-xs uppercase tracking-[0.1em] text-pink-700 font-semibold">Start Fast</p>
          <p class="mt-1 text-sm text-gray-700">Free tier for quick validation before committing budget.</p>
        </div>
        <div class="rounded-xl border border-[var(--line-soft)] bg-[var(--brand-50)] p-4">
          <p class="text-xs uppercase tracking-[0.1em] text-pink-700 font-semibold">Scale Cleanly</p>
          <p class="mt-1 text-sm text-gray-700">Higher queue limits for bigger campaigns and follow-up volume.</p>
        </div>
        <div class="rounded-xl border border-[var(--line-soft)] bg-[var(--brand-50)] p-4">
          <p class="text-xs uppercase tracking-[0.1em] text-pink-700 font-semibold">Control Risk</p>
          <p class="mt-1 text-sm text-gray-700">Plan-based limits and settings keep automation predictable.</p>
        </div>
      </div>

      <div class="mt-7 flex flex-col sm:flex-row gap-3">
        <Link
          href={isConversion ? "/pricing" : "https://chromewebstore.google.com/detail/agent-for-whatsapp/kjeodciaphncjcogidpafdeeckmpdcpn"}
          data-cta={isConversion ? "final_open_pricing" : "final_install"}
          data-location="final_cta"
          class="bg-pink-600 hover:bg-pink-700 text-white rounded-xl font-semibold text-center"
          target={isConversion ? undefined : "_blank"}
          rel={isConversion ? undefined : "noopener"}
        >
          {isConversion ? "View Plans and Limits" : "Install Free on Chrome"}
        </Link>
        <Link
          href={isConversion ? "https://chromewebstore.google.com/detail/agent-for-whatsapp/kjeodciaphncjcogidpafdeeckmpdcpn" : "/pricing"}
          data-cta={isConversion ? "final_install_after_pricing" : "final_view_pricing"}
          data-location="final_cta"
          class="bg-white border border-[var(--line-soft)] rounded-xl font-semibold text-gray-900 hover:bg-[var(--brand-50)] text-center"
          target={isConversion ? "_blank" : undefined}
          rel={isConversion ? "noopener" : undefined}
        >
          {isConversion ? "Install Free on Chrome" : "View Pricing"}
        </Link>
      </div>
  </div>

  <div class="bg-[var(--brand-50)] p-6 sm:p-8 lg:p-10 border-t border-[var(--line-soft)]">
      <p class="text-xs uppercase tracking-[0.18em] text-pink-600 font-semibold">What You Get Today</p>
      <ul class="mt-4 space-y-3 text-sm text-gray-700">
        <li class="flex gap-2 items-start">
          <Icon name="mdi:check-circle" class="w-5 h-5 text-pink-500 mt-0.5" />
          <span>Lead pipeline tools: Lead Management, Batch Sender, and Scheduled Message</span>
        </li>
        <li class="flex gap-2 items-start">
          <Icon name="mdi:check-circle" class="w-5 h-5 text-pink-500 mt-0.5" />
          <span>Usage dashboard with connection health and reply trend</span>
        </li>
        <li class="flex gap-2 items-start">
          <Icon name="mdi:check-circle" class="w-5 h-5 text-pink-500 mt-0.5" />
          <span>Connector flexibility: OpenAI, OpenRouter, Groq, Gemini, and Local models</span>
        </li>
        <li class="flex gap-2 items-start">
          <Icon name="mdi:check-circle" class="w-5 h-5 text-pink-500 mt-0.5" />
          <span>Operational controls: trigger mode, persona, limits, and quiet hours</span>
        </li>
      </ul>

      <div class="mt-7 flex flex-col sm:flex-row gap-3">
        <Link
          href="/pricing"
          data-cta="final_compare_limits"
          data-location="final_cta_side"
          class="bg-white border border-[var(--line-soft)] rounded-xl font-semibold text-gray-900 hover:bg-[var(--brand-50)] text-center"
        >
          Compare Limits
        </Link>
        <Link
          href="/tools/whatsapp-reply-generator"
          data-cta="final_try_free_tool"
          data-location="final_cta_side"
          class="bg-white border border-[var(--line-soft)] rounded-xl font-semibold text-gray-900 hover:bg-[var(--brand-50)] text-center"
        >
          Try Free Tool
        </Link>
      </div>
  </div>
</section>
