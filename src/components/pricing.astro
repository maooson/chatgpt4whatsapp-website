---
import { Tick } from "@components/ui/icons";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
import type { Locale } from "@lib/i18n";
import { getSiteCopy } from "@lib/site-copy";

const { plan, locale = "en" } = Astro.props as { plan: any; locale?: Locale };
const copy = getSiteCopy(locale);
const buttonLink = plan.button.link || "#";
const ctaLink =
  buttonLink === "#"
    ? "#"
    : buttonLink.includes("?")
      ? `${buttonLink}&utm_source=site&utm_medium=pricing&utm_campaign=${plan.name.toLowerCase()}`
      : `${buttonLink}?utm_source=site&utm_medium=pricing&utm_campaign=${plan.name.toLowerCase()}`;

const isPro = plan.name === "Pro";
const isMax = plan.name === "Max";
const isPaid = isPro || isMax;
const badgeText = plan.badge;
const currentPrice = typeof plan.price === "object" ? plan.price.monthly : plan.price;
const originalPrice =
  typeof plan.price === "object" ? plan.price.originalMonthly : undefined;
---

<div class="relative">
  {isPro && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-10">
      <span class="inline-flex items-center gap-1 rounded-full bg-[#EAB308] px-4 py-1.5 text-xs font-bold uppercase tracking-wider text-white">
        <Icon name="mdi:star" class="w-3.5 h-3.5" />
        {copy.pricing.mostPopular}
      </span>
    </div>
  )}

  <div
    class:list={[
      "flex flex-col w-full rounded-2xl border p-7 transition-shadow",
      isPro
        ? "border-[var(--brand-500)] shadow-xl shadow-[var(--brand-500)]/10 ring-1 ring-[var(--brand-500)] bg-white scale-[1.01]"
        : "border-[var(--line-soft)] bg-white/72",
    ]}>

    <!-- Header -->
    <div class="text-center pb-6 border-b border-[var(--line-soft)]">
      <div class="flex items-center justify-center gap-2">
        <h4 class:list={[
          "text-sm font-bold uppercase tracking-widest",
          isPro ? "text-[var(--ink-900)]" : "text-slate-500",
        ]}>{plan.name}</h4>
        {badgeText && (
          <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-[10px] font-bold uppercase tracking-[0.14em] text-slate-500">
            {badgeText}
          </span>
        )}
      </div>

      <div class="mt-4 flex items-baseline justify-center gap-1">
        {isPaid ? (
          <>
            <span class:list={[
              "text-5xl font-extrabold tracking-tight",
              isPro ? "text-[var(--ink-900)]" : "text-[var(--ink-900)]",
            ]}>
              {currentPrice}
            </span>
            <span class="text-gray-500 text-sm font-medium">{copy.pricing.perMonth}</span>
          </>
        ) : (
          <span class="text-5xl font-extrabold tracking-tight text-gray-800">{copy.pricing.free}</span>
        )}
      </div>

      {isPaid && (
        <div class="mt-2 space-y-1">
          {originalPrice && (
            <p class="text-xs font-medium text-gray-400 line-through">{originalPrice}{copy.pricing.perMonth}</p>
          )}
          <p class="text-gray-500 text-xs">{copy.pricing.billedMonthly}</p>
        </div>
      )}
      {!isPaid && (
        <p class="text-gray-500 text-xs mt-2">{copy.pricing.noCard}</p>
      )}
    </div>

    <!-- Features -->
    <ul class="mt-6 space-y-3 flex-1">
      {
        plan.features.map((item, i) => (
          <li class="flex gap-2.5 items-start">
            {i === 0 && isPaid ? (
              <Icon name="mdi:arrow-up-circle" class="w-5 h-5 text-[var(--brand-500)] mt-0.5 shrink-0" />
            ) : (
              <Icon name="mdi:check-circle" class="w-5 h-5 text-[var(--brand-500)] mt-0.5 shrink-0" />
            )}
            <span class:list={[
              "text-sm",
              i === 0 && isPaid ? "font-semibold text-[var(--ink-900)]" : "text-[var(--ink-700)]",
            ]}>{item}</span>
          </li>
        ))
      }
    </ul>

    <!-- CTA -->
    <div class="mt-8">
      <Link
        href={ctaLink || "#"}
        data-cta={`pricing_${plan.name.toLowerCase()}_click`}
        data-location="pricing"
        rel="noopener"
        target="_blank"
        class:list={[
          "block w-full text-center py-3 px-5 rounded-xl font-semibold transition-all text-sm",
          isPro
            ? "bg-[var(--brand-600)] text-white hover:bg-[var(--brand-500)]"
            : isMax
              ? "bg-[var(--brand-600)] text-white hover:bg-[var(--brand-500)]"
              : "bg-white text-[var(--ink-900)] border border-[var(--line-soft)] hover:bg-[var(--brand-50)]",
        ]}>
        {plan.button.text || copy.pricing.getStarted}
      </Link>
    </div>
  </div>
</div>
